APP_NAME=nn-service
LOG_LEVEL=INFO

STREAMS_CONFIG_PATH=/app/config/streams.yaml
CHECKS_CONFIG_PATH=/app/config/checks.yaml

EVENT_SERVICE_BASE_URL=http://host.docker.internal:8000
EVENT_SOURCE=cv
EVENT_DEFAULT_SEVERITY=med
EVENT_DEFAULT_STATUS=open

MEDIA_BUCKET=gasvision-media
MEDIA_BASE_DIR=/tmp/nn-service-media
MEDIA_PUBLIC_BASE_URL=http://localhost:9000/fake-s3

# --- Потоковая обработка ---
FRAME_SAMPLE_EVERY_N=5
DETECTION_CONFIDENCE=0.35
DETECTION_IOU=0.45
TRIGGER_COOLDOWN_SECONDS=30
PRE_EVENT_BUFFER_SECONDS=5
POST_EVENT_RECORD_SECONDS=5
CLIP_FPS=10
MAX_STREAM_RECONNECT_DELAY_SECONDS=10

# --- YOLO ---
YOLO_MODEL_PATH=/app/models/yolov8n.pt
YOLO_DEVICE=cpu
# Включаем person — он нужен для сценариев.
YOLO_CLASSES=person,car,bus,truck,motorcycle
YOLO_PERSON_LABELS=person
YOLO_VEHICLE_LABELS=car,bus,truck,motorcycle
YOLO_TRACKER_CONFIG=bytetrack.yaml

# --- Сценарии / таймеры (сек) ---
PERSON_WITHOUT_CAR_SEC=30
PERSON_TOO_LONG_AT_STATION_SEC=120
CAR_TOO_LONG_SEC=300
EVENT_COOLDOWN_SEC=60

# --- ReID ---
REID_GRACE_SEC=8
REID_RADIUS_PX=150
PERSON_CAR_PROXIMITY_PX=200

# --- Fallback для камер без zones-конфига ---
FALLBACK_FRAME_WIDTH=1920
FALLBACK_FRAME_HEIGHT=1080

# --- Viewer ---
# Web viewer (FastAPI/MJPEG) выключен: при network_mode: "service:vpn" без
# ports на хост его не пробросить. Для визуального контроля используется
# scripts/view_cameras.py — читает storage/detections/<CAM>/latest.jpg.
VIEWER_ENABLED=false
