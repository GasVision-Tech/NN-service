APP_NAME=nn-service
LOG_LEVEL=INFO

STREAMS_CONFIG_PATH=/app/config/streams.yaml

EVENT_SERVICE_BASE_URL=http://host.docker.internal:8000

# EVENT_SERVICE_BASE_URL=http://event-service:8000
EVENT_SOURCE=cv
EVENT_DEFAULT_SEVERITY=med
EVENT_DEFAULT_STATUS=open

MEDIA_BUCKET=gasvision-media
MEDIA_BASE_DIR=/tmp/nn-service-media
MEDIA_PUBLIC_BASE_URL=http://localhost:9000/fake-s3

FRAME_SAMPLE_EVERY_N=5
DETECTION_CONFIDENCE=0.35
DETECTION_IOU=0.45
TRIGGER_COOLDOWN_SECONDS=30
PRE_EVENT_BUFFER_SECONDS=5
POST_EVENT_RECORD_SECONDS=5
CLIP_FPS=10
MAX_STREAM_RECONNECT_DELAY_SECONDS=10

YOLO_MODEL_PATH=/app/models/yolov8n.pt
YOLO_DEVICE=cpu
YOLO_CLASSES=car,bus,truck,motorcycle